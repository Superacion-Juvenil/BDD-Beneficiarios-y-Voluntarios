rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is the admin account
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == 'admin@sj.internal';
    }

    // Helper: requesting user owns this document
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Helper: only safe fields can be updated by the user (not admin-only fields)
    function userSafeFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'nombre', 'apellidoPaterno', 'apellidoMaterno',
          'correo', 'telefono', 'calle', 'colonia', 'cp', 'municipio',
          'tutorNombre', 'tutorTelefono', 'tutorCorreo',
          'escuela', 'carrera', 'gradoEscolar',
          'ocupacion', 'empresa', 'programasSJ',
          'servicio', 'voluntariadoExterno', 'notas',
          'docTerminos', 'docCartaResponsiva', 'docCapacitacionPASI', 'docFechaPASI',
          'updatedAt'
        ]);
    }

    match /users/{uid} {
      // Admins: full read/write on all user documents
      allow read, write: if isAdmin();

      // Owners: can read their own document
      allow read: if isOwner(uid);

      // Owners: can update their own document but only safe fields
      allow update: if isOwner(uid) && userSafeFields();

      // No one else
      allow create, delete: if false;
    }

    // auth_meta: admin-only
    match /auth_meta/{uid} {
      allow read, write: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
